# Supabase (required for leads database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login (server-side only — never expose ADMIN_PASSWORD client-side)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-password-here
ADMIN_SESSION_SECRET=generate-a-long-random-secret-at-least-32-chars

# OpenAI (required for AI lead analysis and lead finder classification)
OPENAI_API_KEY=sk-your-openai-key

# Public lead finder search (configure at least one)
SERPAPI_API_KEY=your-serpapi-key
TAVILY_API_KEY=your-tavily-key
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-cse-key
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-search-engine-id
